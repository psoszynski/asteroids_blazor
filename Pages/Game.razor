@page "/"
@layout EmptyLayout
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject HighScoreService HighScores

@using Asteroids.Game
@using Asteroids.Models
@using Asteroids.Services

<PageTitle>Asteroids</PageTitle>

<div class="game-container">
    <div class="hud">
        <div class="hud-panel hud-left">
            <span class="hud-label">Mission Timer</span>
            <span class="hud-value">@GameMath.FormatTime(_gameState.ElapsedTime)</span>
            <div class="hud-sub">Wave @_gameState.Level · Best @(_bestTime) · @_gameState.AsteroidsRemaining asteroids</div>
        </div>

        <div class="hud-panel hud-center">
            <div class="hud-center-header">
                <span class="hud-label">Score</span>
                <button class="hud-pause-btn" @onclick="OnPauseToggle" title="Press P to Pause/Resume">
                    @(_gameState.IsPaused ? "▶ RESUME" : "❚❚ PAUSE")
                </button>
            </div>
            <span class="hud-value">@_gameState.Score.ToString("N0")</span>
            @if (_gameState.HasShield || _gameState.RapidFireRemaining > 0 || _gameState.TripleShotRemaining > 0)
            {
                <div class="powerup-bar">
                    @if (_gameState.HasShield)
                    {
                        <span class="powerup-badge powerup-shield">SHIELD</span>
                    }
                    @if (_gameState.RapidFireRemaining > 0)
                    {
                        <span class="powerup-badge powerup-rapid">RAPID @_gameState.RapidFireRemaining.ToString("0.0")s</span>
                    }
                    @if (_gameState.TripleShotRemaining > 0)
                    {
                        <span class="powerup-badge powerup-triple">TRIPLE @_gameState.TripleShotRemaining.ToString("0.0")s</span>
                    }
                </div>
            }
        </div>

        <div class="hud-panel hud-right">
            <span class="hud-label">Shields</span>
            <div class="lives-display">
                @for (var i = 0; i < GameConstants.InitialLives; i++)
                {
                    <span class="life-pip @(i < _gameState.Lives ? "" : "spent")"></span>
                }
            </div>
            <div class="build-info">ASTEROIDS · BLAZOR WASM</div>
        </div>

        @if (_gameState.IsPaused && !_gameOverLatched)
        {
            <div class="overlay-pause" @onclick="OnPauseToggle">
                <div class="pause-title">PAUSED</div>
                <div class="pause-hint">Tap here or press P to resume</div>
                
                <div class="leaderboard-panel">
                    <div class="leaderboard-title">🏆 LEADERBOARD</div>
                    @RenderLeaderboard()
                </div>
            </div>
        }

        @if (_gameState.IsWaveTransition)
        {
            <div class="overlay-wave">
                <div class="wave-title">WAVE @_gameState.Level</div>
                <div class="wave-subtitle">@GameMath.GetWaveAsteroidCount(_gameState.Level) asteroids incoming</div>
            </div>
        }

        @if (_gameOverLatched)
        {
            <div class="overlay-gameover">
                <div class="gameover-title">GAME OVER</div>
                <div class="gameover-stats">
                    <div>Score: @_gameState.Score.ToString("N0")</div>
                    <div>Wave @_gameState.Level reached</div>
                    <div>Survival Time: @GameMath.FormatTime(_gameState.ElapsedTime)</div>
                </div>
                
                <div class="leaderboard-panel">
                    <div class="leaderboard-title">🏆 LEADERBOARD</div>
                    @RenderLeaderboard()
                </div>

                <div class="gameover-hint desktop-only">Press SPACEBAR to restart</div>
                <button class="mobile-restart-btn" @onclick="OnMobileRestart">TAP TO RESTART</button>
            </div>
        }
    </div>

    <canvas @ref="_canvasRef" class="game-canvas"></canvas>

    <div class="touch-zones-container">
        <div class="touch-zone zone-rotate-left" id="touch-left">
            <span class="zone-icon">◀</span>
            <span class="zone-label">ROTATE</span>
        </div>
        <div class="touch-zone zone-thrust" id="touch-thrust">
            <span class="zone-icon">▲</span>
            <span class="zone-label">THRUST</span>
        </div>
        <div class="touch-zone zone-rotate-right" id="touch-right">
            <span class="zone-icon">▶</span>
            <span class="zone-label">ROTATE</span>
        </div>
        <div class="touch-zone zone-fire" id="touch-fire">
            <span class="zone-icon">✸</span>
            <span class="zone-label">FIRE</span>
        </div>
    </div>
</div>

@code {
    private ElementReference _canvasRef;
    private DotNetObjectReference<Game>? _dotNetRef;
    private readonly GameEngine _engine = new();
    private GameState _gameState = CreateInitialGameState();
    private List<HighScoreEntry> _highScores = [];
    private string _bestTime = "--:--";
    private System.Threading.Timer? _hudTimer;
    private bool _initialized;
    private readonly List<HighScoreEntry> _pendingScores = [];
    private bool _gameOverLatched;
    private bool _restartInProgress;

    // Global Leaderboard variables
    private bool _showGlobalLeaderboard = true;
    private List<HighScoreEntry>? _globalScores;
    private bool _loadingGlobal;
    private string _username = "";
    private string _usernameInput = "";
    private string _registerError = "";
    private bool _registering;
    private int _lastRunScore;
    private double _lastRunTime;
    private bool _scoreSubmitted;
    private string _savedRecoveryCode = "";
    private string _recoveryInput = "";
    private bool _showRecoveryInput;

    private RenderFragment RenderLeaderboard() => __builder =>
    {
        <div class="leaderboard-tabs">
            <button class="tab-btn @(!_showGlobalLeaderboard ? "active" : "")" @onclick="() => ToggleLeaderboardTab(false)">LOCAL</button>
            <button class="tab-btn @(_showGlobalLeaderboard ? "active" : "")" @onclick="() => ToggleLeaderboardTab(true)">GLOBAL</button>
        </div>

        if (!_showGlobalLeaderboard)
        {
            if (_highScores.Count == 0)
            {
                <div class="leaderboard-empty">No local records yet</div>
            }
            else
            {
                <div class="leaderboard-list">
                    @for (var idx = 0; idx < Math.Min(5, _highScores.Count); idx++)
                    {
                        var entry = _highScores[idx];
                        <div class="leaderboard-row">
                            <span class="leaderboard-rank">#@(idx + 1)</span>
                            <div class="leaderboard-entry">
                                <span class="leaderboard-value">@entry.Score.ToString("N0") (@GameMath.FormatTime(entry.SurvivalTime))</span>
                                <span class="leaderboard-date">@GameMath.FormatPlayedAt(entry.PlayedAt)</span>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            if (_loadingGlobal)
            {
                <div class="leaderboard-empty loading-spinner">Loading global scores...</div>
            }
            else if (_globalScores == null)
            {
                <div class="leaderboard-empty">Failed to load global scores</div>
            }
            else if (_globalScores.Count == 0)
            {
                <div class="leaderboard-empty">No global records yet</div>
            }
            else
            {
                <div class="leaderboard-list">
                    @for (var idx = 0; idx < Math.Min(5, _globalScores.Count); idx++)
                    {
                        var entry = _globalScores[idx];
                        <div class="leaderboard-row">
                            <span class="leaderboard-rank">#@(idx + 1)</span>
                            <div class="leaderboard-entry">
                                <span class="leaderboard-name">@(entry.Username ?? "Anonymous")</span>
                                <span class="leaderboard-value">@entry.Score.ToString("N0") (@GameMath.FormatTime(entry.SurvivalTime))</span>
                            </div>
                        </div>
                    }
                </div>
            }

            if (string.IsNullOrEmpty(_username) && _gameOverLatched)
            {
                if (!_showRecoveryInput)
                {
                    <div class="registration-panel">
                        <div class="reg-title">Claim username to submit score:</div>
                        <div class="reg-form">
                            <input class="reg-input" placeholder="Name (3-20 chars)" @bind="_usernameInput" @bind:event="oninput" maxlength="20" disabled="@_registering" />
                            <button class="reg-btn" @onclick="RegisterAndSubmitScore" disabled="@_registering">
                                @(_registering ? "..." : "CLAIM")
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_registerError))
                        {
                            <div class="reg-error">@_registerError</div>
                        }
                    </div>
                }
                else
                {
                    <div class="registration-panel">
                        <div class="reg-title">Name '@_usernameInput' is taken. Enter Recovery Code:</div>
                        <div class="reg-form">
                            <input class="reg-input" placeholder="Code (e.g. XYZ123)" @bind="_recoveryInput" @bind:event="oninput" maxlength="6" disabled="@_registering" />
                            <button class="reg-btn" @onclick="SubmitRecoveryCodeAndRegister" disabled="@_registering">
                                @(_registering ? "..." : "VERIFY")
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_registerError))
                        {
                            <div class="reg-error">@_registerError</div>
                        }
                        <button class="tab-btn" style="margin-top: 4px; padding: 4px 8px; pointer-events: auto;" @onclick="CancelRecovery">Choose other name</button>
                    </div>
                }
            }
            else if (!string.IsNullOrEmpty(_username) && _gameOverLatched)
            {
                <div class="reg-welcome">
                    Playing as: <span class="reg-username">@_username</span>
                    @if (!string.IsNullOrEmpty(_savedRecoveryCode))
                    {
                        <div style="font-size: 10px; color: rgba(110, 220, 255, 0.4); margin-top: 2px;">
                            Recovery Code: <span style="color: rgba(110, 220, 255, 0.7); font-weight: bold;">@_savedRecoveryCode</span> (save to link other tabs/browsers)
                        </div>
                    }
                </div>
            }
        }
    };

    private void ToggleLeaderboardTab(bool showGlobal)
    {
        _showGlobalLeaderboard = showGlobal;
        if (showGlobal && _globalScores == null)
        {
            _ = LoadGlobalLeaderboardAsync();
        }
    }

    private async Task LoadGlobalLeaderboardAsync()
    {
        if (_loadingGlobal) return;
        _loadingGlobal = true;
        _registerError = "";
        StateHasChanged();
        
        try
        {
            _globalScores = await HighScores.GetGlobalHighScoresAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadGlobal Error] {ex}");
        }
        finally
        {
            _loadingGlobal = false;
            StateHasChanged();
        }
    }

    private async Task RegisterAndSubmitScore()
    {
        if (string.IsNullOrWhiteSpace(_usernameInput))
        {
            _registerError = "Username cannot be empty.";
            return;
        }

        _registerError = "";
        _registering = true;
        _showRecoveryInput = false;
        StateHasChanged();

        try
        {
            var regResult = await HighScores.RegisterUsernameAsync(_usernameInput);
            if (regResult.Success)
            {
                _username = regResult.CleanedName;
                _savedRecoveryCode = regResult.RecoveryCode;
                await HighScores.SaveUsernameAsync(_username);
                await HighScores.SaveRecoveryCodeAsync(_savedRecoveryCode);
                
                if (_lastRunScore > 0 && !_scoreSubmitted)
                {
                    var success = await HighScores.SubmitGlobalScoreAsync(_username, _lastRunScore, _lastRunTime);
                    if (success)
                    {
                        _scoreSubmitted = true;
                    }
                }
                
                _ = LoadGlobalLeaderboardAsync();
            }
            else
            {
                if (regResult.CodeRequired)
                {
                    _showRecoveryInput = true;
                    _recoveryInput = "";
                }
                _registerError = regResult.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            _registerError = $"Error: {ex.Message}";
        }
        finally
        {
            _registering = false;
            StateHasChanged();
        }
    }

    private async Task SubmitRecoveryCodeAndRegister()
    {
        if (string.IsNullOrWhiteSpace(_recoveryInput))
        {
            _registerError = "Recovery code cannot be empty.";
            return;
        }

        _registerError = "";
        _registering = true;
        StateHasChanged();

        try
        {
            var regResult = await HighScores.RegisterUsernameAsync(_usernameInput, _recoveryInput);
            if (regResult.Success)
            {
                _username = regResult.CleanedName;
                _savedRecoveryCode = regResult.RecoveryCode;
                _showRecoveryInput = false;
                await HighScores.SaveUsernameAsync(_username);
                await HighScores.SaveRecoveryCodeAsync(_savedRecoveryCode);
                
                if (_lastRunScore > 0 && !_scoreSubmitted)
                {
                    var success = await HighScores.SubmitGlobalScoreAsync(_username, _lastRunScore, _lastRunTime);
                    if (success)
                    {
                        _scoreSubmitted = true;
                    }
                }
                
                _ = LoadGlobalLeaderboardAsync();
            }
            else
            {
                _registerError = regResult.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            _registerError = $"Error: {ex.Message}";
        }
        finally
        {
            _registering = false;
            StateHasChanged();
        }
    }

    private void CancelRecovery()
    {
        _showRecoveryInput = false;
        _registerError = "";
        _usernameInput = "";
        StateHasChanged();
    }

    private void RefreshBestTime() =>
        _bestTime = _highScores.Count > 0
            ? $"{_highScores[0].Score.ToString("N0")} ({GameMath.FormatTime(_highScores[0].SurvivalTime)})"
            : "--";

    private static GameState CreateInitialGameState() => new()
    {
        Lives = GameConstants.InitialLives,
        ElapsedTime = 0,
        IsGameOver = false,
        IsPaused = false,
        Score = 0,
        Level = 1,
        IsWaveTransition = false,
        AsteroidsRemaining = 0
    };

    private static GameState CopyGameState(GameState source) => new()
    {
        Lives = source.Lives,
        ElapsedTime = source.ElapsedTime,
        IsGameOver = source.IsGameOver,
        IsPaused = source.IsPaused,
        Score = source.Score,
        Level = source.Level,
        IsWaveTransition = source.IsWaveTransition,
        HasShield = source.HasShield,
        RapidFireRemaining = source.RapidFireRemaining,
        TripleShotRemaining = source.TripleShotRemaining,
        AsteroidsRemaining = source.AsteroidsRemaining
    };

    /// <summary>
    /// Applies engine HUD snapshot into component state. Latches game-over so the overlay
    /// cannot be cleared by a later stale snapshot.
    /// </summary>
    private void ApplyHudSnapshot(GameState source, bool requestRender)
    {
        if (source.IsGameOver)
        {
            _gameOverLatched = true;
        }

        var next = CopyGameState(source);
        if (_gameOverLatched)
        {
            next.IsGameOver = true;
            next.IsPaused = false;
        }

        _gameState = next;

        if (requestRender)
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized) return;
        _initialized = true;

        _highScores = await HighScores.GetHighScoresAsync();
        RefreshBestTime();

        _username = await HighScores.GetSavedUsernameAsync() ?? "";
        _usernameInput = _username;
        _savedRecoveryCode = await HighScores.GetSavedRecoveryCodeAsync() ?? "";
        _ = LoadGlobalLeaderboardAsync();

        _engine.OnScoreRecorded = (score, time) => _pendingScores.Add(new HighScoreEntry { Score = score, SurvivalTime = time });

        _dotNetRef = DotNetObjectReference.Create(this);

        var width = await JS.InvokeAsync<int>("gameLoop.getViewportWidth");
        var height = await JS.InvokeAsync<int>("gameLoop.getViewportHeight");
        _engine.Initialize(width, height);

        await JS.InvokeVoidAsync("gameLoop.start", _canvasRef, _dotNetRef);

        _hudTimer = new System.Threading.Timer(_ =>
        {
            _engine.SyncHudState();
            _ = InvokeAsync(() =>
            {
                ApplyHudSnapshot(_engine.State, requestRender: false);
                StateHasChanged();
            });
        }, null, 100, 100);
    }

    [JSInvokable]
    public void OnResize(int width, int height)
    {
        // Never re-initialize after the run has started or once game over is latched.
        if (_gameOverLatched || _engine.State.IsGameOver || _engine.State.ElapsedTime > 0)
        {
            _engine.Resize(width, height);
        }
        else
        {
            _engine.Initialize(width, height);
        }
    }

    [JSInvokable]
    public FrameResult OnFrame(double deltaMs, InputState? input)
    {
        input ??= new InputState();
        var result = _engine.Update(deltaMs, input);

        var hud = result.HudState;
        var needsImmediateRender =
            hud.IsGameOver != _gameState.IsGameOver ||
            hud.IsPaused != _gameState.IsPaused ||
            hud.IsWaveTransition != _gameState.IsWaveTransition ||
            hud.Level != _gameState.Level ||
            hud.HasShield != _gameState.HasShield ||
            Math.Abs(hud.RapidFireRemaining - _gameState.RapidFireRemaining) > 0.05 ||
            Math.Abs(hud.TripleShotRemaining - _gameState.TripleShotRemaining) > 0.05 ||
            (hud.IsGameOver && !_gameOverLatched);

        if (needsImmediateRender)
        {
            ApplyHudSnapshot(hud, requestRender: true);
        }

        if (_pendingScores.Count > 0)
        {
            result.PendingScores = [.._pendingScores];
            _pendingScores.Clear();
        }

        return result;
    }

    [JSInvokable]
    public async Task HandleFrameEvents(bool shouldReset, HighScoreEntry[] pendingScores)
    {
        try
        {
            foreach (var entry in pendingScores)
            {
                _highScores = await HighScores.AddHighScoreAsync(entry.Score, entry.SurvivalTime);
                _lastRunScore = entry.Score;
                _lastRunTime = entry.SurvivalTime;
                _scoreSubmitted = false;
                
                if (!string.IsNullOrEmpty(_username))
                {
                    var success = await HighScores.SubmitGlobalScoreAsync(_username, entry.Score, entry.SurvivalTime);
                    if (success)
                    {
                        _scoreSubmitted = true;
                    }
                    _ = LoadGlobalLeaderboardAsync();
                }
            }

            if (pendingScores.Length > 0)
            {
                RefreshBestTime();
                // Keep game-over overlay visible while leaderboard text updates.
                if (_gameOverLatched)
                {
                    StateHasChanged();
                }
            }

            if (shouldReset)
            {
                await RestartGameAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[HandleFrameEvents Error] {ex}");
        }
    }

    private async Task OnMobileRestart()
    {
        if (!_engine.CanRestartFromGameOver()) return;
        await RestartGameAsync();
    }

    private async Task RestartGameAsync()
    {
        if (_restartInProgress) return;
        _restartInProgress = true;

        try
        {
            _gameOverLatched = false;
            _engine.ResetGame();
            _highScores = await HighScores.GetHighScoresAsync();
            RefreshBestTime();
            ApplyHudSnapshot(_engine.State, requestRender: false);
            StateHasChanged();
        }
        finally
        {
            _restartInProgress = false;
        }
    }

    private async Task OnPauseToggle()
    {
        await JS.InvokeVoidAsync("gameLoop.togglePause");
    }

    public async ValueTask DisposeAsync()
    {
        _hudTimer?.Dispose();
        if (_initialized)
        {
            await JS.InvokeVoidAsync("gameLoop.stop");
        }
        _dotNetRef?.Dispose();
    }
}